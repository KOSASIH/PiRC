# PiRC RT Kernel Config (PREEMPT_RT)
CONFIG_PREEMPT_RT=y
CONFIG_PREEMPT=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_NO_HZ_FULL=y
CONFIG_HZ_1000=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y

# PiRC Hardware Support
CONFIG_RPI_GPIO=y
CONFIG_I2C_BCM2835=y
CONFIG_CAN_BCM=y
CONFIG_V4L_PLATFORM_DRIVERS=y
CONFIG_VIDEO_CADENCE=y
CONFIG_VIDEO_BCM2835=y

# Real-time optimizations
CONFIG_ISOLCPU=0-3
CONFIG_RCU_NOCB_CPU=0-3
CONFIG_PREEMPT_LAZY=y
