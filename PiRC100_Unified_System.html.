<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PiRC-100 | Unified Monetary System</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-bg: #030303;
            --card-bg: #0a0a0c;
            --pi-gold: #FFD700;
            --pi-purple: #7e22ce;
            --success: #10b981;
            --warning: #f59e0b;
            --info: #0ea5e9;
            --text-dim: #9ca3af;
            --border: #1f1f23;
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--primary-bg);
            color: #ffffff;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        /* Live Status Bar */
        .status-bar {
            background: rgba(0,0,0,0.9);
            backdrop-filter: blur(10px);
            padding: 12px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .network-status { display: flex; align-items: center; gap: 8px; font-size: 11px; font-weight: 700; color: var(--pi-purple); text-transform: uppercase;}
        .dot { width: 8px; height: 8px; background: var(--pi-purple); border-radius: 50%; box-shadow: 0 0 10px var(--pi-purple); animation: pulse 2s infinite; }

        /* Main Header */
        header { padding: 30px 20px; text-align: left; background: linear-gradient(to bottom, #0a0a0c, var(--primary-bg)); border-bottom: 1px solid var(--border);}
        header h1 { margin: 0; font-size: 22px; letter-spacing: -0.8px; font-weight: 800; }
        header p { margin: 5px 0 0; color: var(--text-dim); font-size: 13px; }

        .container { padding: 0 15px 120px; max-width: 500px; margin: auto; }

        .section-title { font-size: 12px; text-transform: uppercase; color: var(--text-dim); letter-spacing: 1.5px; margin: 25px 0 10px 5px; font-weight: 700;}

        /* Unified Valuation Card */
        .valuation-card {
            background: linear-gradient(160deg, #111115 0%, #030303 100%);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 24px;
            margin-bottom: 20px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }

        .price-type { font-size: 11px; text-transform: uppercase; color: var(--text-dim); letter-spacing: 1px; font-weight: 600; margin-bottom: 5px;}
        
        /* Exchange Price */
        .exchange-row { margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--border); }
        .price-ex-val { font-family: 'JetBrains Mono', monospace; font-size: 36px; font-weight: 700; color: var(--text-dim); }
        
        /* Internal Price */
        .internal-row { }
        .price-in-val { font-family: 'JetBrains Mono', monospace; font-size: 40px; font-weight: 700; color: var(--pi-gold); display: flex; align-items: center; gap: 10px;}
        .utility-tag { font-size: 10px; background: rgba(255, 215, 0, 0.1); color: var(--pi-gold); padding: 4px 8px; border-radius: 4px; border: 1px solid rgba(255,215,0,0.2); }

        /* The Justice Formula Visualization */
        .formula-card {
            background: #070709;
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 20px;
            font-family: 'JetBrains Mono', monospace;
            text-align: center;
        }
        .formula-text { color: var(--text-dim); font-size: 13px; }
        .highlight-ex { color: white; font-weight: 700; }
        .highlight-in { color: var(--pi-gold); font-weight: 700; }
        .formula-icon { font-size: 20px; margin: 10px 0; color: var(--pi-purple); animation: convertPulse 3s infinite; }

        /* Integity (Ze0ro99) */
        .integrity-box {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 16px;
            border-left: 4px solid var(--info);
            margin-bottom: 15px;
        }
        .hash { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--info); word-break: break-all; opacity: 0.8; margin-top: 8px;}

        /* Action Button */
        .btn-primary {
            background: linear-gradient(180deg, var(--pi-gold) 0%, #e6c300 100%);
            color: #000;
            border: none;
            width: 100%;
            padding: 20px;
            border-radius: 16px;
            font-weight: 800;
            font-size: 16px;
            text-transform: uppercase;
            cursor: pointer;
            box-shadow: 0 10px 30px rgba(255, 215, 0, 0.2);
            transition: all 0.2s;
            position: fixed;
            bottom: 20px;
            left: 15px;
            right: 15px;
            max-width: 470px;
            margin: auto;
            z-index: 90;
        }

        .btn-primary:active { transform: scale(0.97); opacity: 0.9; }

        footer { text-align: center; color: #444; font-size: 10px; padding: 20px 0; line-height: 1.6; }

        @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }
        @keyframes convertPulse { 0% { transform: scale(1); opacity: 0.5; } 50% { transform: scale(1.1); opacity: 1; } 100% { transform: scale(1); opacity: 0.5; } }

    </style>
</head>
<body>

    <div class="status-bar">
        <div class="network-status">
            <div class="dot"></div>
            PiRC-100 Justice Engine Live
        </div>
    </div>

    <header>
        <h1>Unified Monetary System</h1>
        <p>Strategic Architecture by <strong>EslaM-X</strong></p>
    </header>

    <div class="container">
        
        <div class="section-title">Valuation Split</div>

        <div class="valuation-card">
            
            <div class="exchange-row">
                <div class="price-type">Exchange Unit Price (Speculative $Pi)</div>
                <div class="price-ex-val">$<span id="priceExVal">3.141</span><span style="font-size:18px;">/M</span></div>
                <div style="font-size:12px; color:var(--text-dim); margin-top:5px;">Price per 1 Million Units on External Exchanges</div>
            </div>

            <div class="internal-row">
                <div class="price-type" style="color:var(--pi-gold);">Internal Utility Pi ($<span style="font-family:serif;">π</span>)</div>
                <div class="price-in-val">$<span id="priceInVal">0.314</span> <span class="utility-tag">PiRC-100 Native</span></div>
                <div style="font-size:12px; color:var(--success); margin-top:8px;">▲ Utility-First Real-World Value</div>
            </div>
        </div>

        <div class="section-title">Justice Engine Mechanism</div>

        <div class="formula-card">
            <div class="formula-text">
                THE CONVERSION TRUTH:<br><br>
                A <span class="highlight-ex">10 Million</span> Unit Weighted Pool of Exchange $Pi<br>
                <div class="formula-icon">⇌</div>
                Creates <span class="highlight-in">1 Internal Utility Pi</span>
            </div>
        </div>

        <div class="integrity-box">
            <div style="display: flex; justify-content: space-between; align-items: center; font-size: 11px; font-weight: 700;">
                <span style="color:var(--info);">PiRC-45 Metadata Hash</span>
                <span style="color: var(--warning);">LIVE_SYNC</span>
            </div>
            <div class="hash" id="liveHash">
                af8a9b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f12
            </div>
        </div>

        <button class="btn-primary" onclick="initializeTransaction()">Synchronize & Execute</button>

        <footer>
            PiRC Ecosystem Standards #2 | Total Unified Structure<br>
            Contributors: EslaM-X (Architecture), Ze0ro99 (Integrity), Clawue884 (Liquidity)<br>
            A sovereign deterministic framework &copy; 2026
        </footer>
    </div>

    <script>
        // Simulate Price Fluctuations
        function updatePrices() {
            // Internal Price (Base: 0.314159)
            const internalBase = 0.314159;
            const inDrift = (Math.random() * 0.0002) - 0.0001;
            const finalInternal = (internalBase + inDrift).toFixed(6);
            document.getElementById('priceInVal').innerText = finalInternal;

            // Exchange Price (Base: 3.141592)
            const exchangeBase = 3.141592;
            const exDrift = (Math.random() * 0.01) - 0.005; // More speculative drift
            const finalExchange = (exchangeBase + exDrift).toFixed(6);
            document.getElementById('priceExVal').innerText = finalExchange;
        }
        setInterval(updatePrices, 2500);

        // Regenerate Hash (PiRC-45 Logic)
        function updateHash() {
            const chars = 'abcdef0123456789';
            let newHash = '';
            for (let i = 0; i < 64; i++) {
                newHash += chars.charAt(Math.floor(Math.random() * chars.length));
            }
            document.getElementById('liveHash').innerText = newHash;
        }
        setInterval(updateHash, 4000);

        // Interaction Feedback
        function initializeTransaction() {
            const btn = document.querySelector('.btn-primary');
            btn.innerText = "VERIFYING CONVERSION...";
            btn.style.background = "white";
            btn.style.color = "black";
            
            setTimeout(() => {
                const exPrice = document.getElementById('priceExVal').innerText;
                const inPrice = document.getElementById('priceInVal').innerText;
                btn.innerText = "SYNCHRONIZED ✔";
                btn.style.background = "var(--success)";
                btn.style.color = "white";
                
                alert(`PiRC-100 Justice Engine Activated.\n\n`+
                      `Current Exchange Rate: $${exPrice}/M (Speculative)\n`+
                      `Current Internal Rate: $${inPrice} (Utility-First)\n\n`+
                      `Weighted Split (WCF): Verifying 10,000,000 unit pool against active engagement.`);
            }, 1800);
        }

    </script>
</body>
</html>

